<Window x:Class="WorkTracker.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="650" Width="950"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        Icon="pack://application:,,,/app_icon.png">

    <Window.Resources>
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="45" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CaptionButtonStyleClose" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FEE2E2" />
                    <Setter Property="Foreground" Value="#EF4444" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="6" 
                      GlassFrameThickness="0,0,1,0"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" /> <!-- Left Sidebar Navigation -->
            <ColumnDefinition Width="*" />   <!-- Content Area -->
        </Grid.ColumnDefinitions>

        <!-- Custom Caption Buttons (Top Right Corner of entire window) -->
        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Height="40" Margin="0,0,10,0" WindowChrome.IsHitTestVisibleInChrome="True" Panel.ZIndex="999">
            <Button Style="{StaticResource CaptionButtonStyle}" Content="—" Click="MinimizeBtn_Click" ToolTip="Minimize"/>
            <Button Style="{StaticResource CaptionButtonStyleClose}" Content="✕" Click="CloseBtn_Click" ToolTip="Close"/>
        </StackPanel>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="15,35,15,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Logo/Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="⚙️ Settings" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Tabs Buttons -->
                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <Button Content="📋  App Rules" Command="{Binding SetSettingsTabCommand}" CommandParameter="App Rules">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSettingsTab}" Value="App Rules">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📅  Calendar Integration" Command="{Binding SetSettingsTabCommand}" CommandParameter="Calendar">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSettingsTab}" Value="Calendar">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🌴  Holidays" Command="{Binding SetSettingsTabCommand}" CommandParameter="Holidays">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSettingsTab}" Value="Holidays">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📅  Work Schedule" Command="{Binding SetSettingsTabCommand}" CommandParameter="Schedule">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSettingsTab}" Value="Schedule">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🛠️  Diagnostics &amp; Logs" Command="{Binding SetSettingsTabCommand}" CommandParameter="Diagnostics">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSettingsTab}" Value="Diagnostics">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🚀  Update" Command="{Binding SetSettingsTabCommand}" CommandParameter="Update">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSettingsTab}" Value="Update">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="ℹ️  About App" Command="{Binding SetSettingsTabCommand}" CommandParameter="About">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSettingsTab}" Value="About">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Footer back button -->
                <Button Grid.Row="3" Content="↩️  Back to Dashboard" Click="CloseBtn_Click" Style="{StaticResource ModernButtonStyle}" Height="36" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
            </Grid>
        </Border>

        <!-- Content Area (Right) -->
        <Grid Grid.Column="1" Margin="25,35,25,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="*" />    <!-- Active View -->
            </Grid.RowDefinitions>

            <!-- Dynamic Header depending on Tab -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="{Binding CurrentSettingsTab}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center" />
            </Grid>

            <!-- Active View Containers -->

            <!-- 1. APP RULES VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentSettingsTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter='App Rules'}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- App List Card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="App Classifications" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,12"/>
                        
                        <ListView Grid.Row="1" ItemsSource="{Binding AppCategories}"
                                  SelectedItem="{Binding SelectedAppCategory, Mode=TwoWay}"
                                  Background="Transparent" BorderThickness="0">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource HoverBgBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EEF2FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ProcessName}" FontWeight="SemiBold"
                                                       FontSize="13" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Background="{StaticResource HoverBgBrush}" BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="8,3">
                                                <TextBlock Text="{Binding CategoryName}" FontSize="11"
                                                           FontWeight="Bold" Foreground="{StaticResource TextSecBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Edit Panel Card -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0" VerticalAlignment="Top" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Edit App Rule" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="Process Name:" FontSize="11" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SelectedProcessName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}"
                                 Padding="8" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="Category:" FontSize="11" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,4"/>
                        <ComboBox SelectedValue="{Binding SelectedCategoryValue}" SelectedValuePath="Content"
                                  Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}"
                                  Padding="8" Margin="0,0,0,18">
                            <ComboBoxItem Content="Work"/>
                            <ComboBoxItem Content="Meeting"/>
                            <ComboBoxItem Content="Leisure"/>
                            <ComboBoxItem Content="Ignore"/>
                        </ComboBox>
                        
                        <Button Content="Save Classification" Command="{Binding SaveCategoryCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,8" Height="36"/>
                        <Button Content="Delete Classification" Command="{Binding DeleteCategoryCommand}"
                                Style="{StaticResource ModernButtonStyle}" Foreground="#EF4444" BorderBrush="#FCA5A5" Height="36"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 2. CALENDAR INTEGRATION VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentSettingsTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=Calendar}">
                <!-- Content Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Configure your Calendar Sync" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="Auto-imports calendar events every hour. Events containing 'Avspass' or 'Fri' will be registered as time off and reduce the flex balance." FontSize="11" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,18" TextWrapping="Wrap"/>

                            <!-- ICS URL Input -->
                            <TextBlock Text="Google Calendar ICS URL:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding IcsCalendarUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}"
                                     Padding="8" Margin="0,0,0,12" TextWrapping="Wrap" AcceptsReturn="False"
                                     ToolTip="Paste your Google Calendar secret ICS URL here"/>

                            <!-- Min Import Date Picker -->
                            <TextBlock Text="Import events starting from (and not before):" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding IcsMinImportDate, UpdateSourceTrigger=PropertyChanged}"
                                        Padding="5" Margin="0,0,0,18"
                                        ToolTip="Select the start date. Events before this date will not be imported."/>

                            <!-- Actions -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="💾 Save Settings" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveIcsUrlCommand}" Padding="20,10" Margin="0,0,10,0" Height="36"/>
                                <Button Content="🔄 Sync Now" Style="{StaticResource ModernButtonStyle}" Command="{Binding SyncIcsNowCommand}" Padding="20,10" Height="36"/>
                            </StackPanel>

                            <!-- Sync Status -->
                            <TextBlock Text="{Binding IcsSyncStatus}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 3. HOLIDAY REGISTRATION VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentSettingsTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=Holidays}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Inputs Card -->
                    <RowDefinition Height="*" />    <!-- List Card -->
                </Grid.RowDefinitions>

                <!-- Inputs Card -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,15" Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                 <TextBlock Text="From Date:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,4"/>
                                 <DatePicker SelectedDate="{Binding HolidayStartDate, Mode=TwoWay}" Padding="4" Height="30" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                 <TextBlock Text="To Date:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,4"/>
                                 <DatePicker SelectedDate="{Binding HolidayEndDate, Mode=TwoWay}" Padding="4" Height="30" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            
                            <Button Grid.Column="4" Content="Register Holiday" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding RegisterHolidayCommand}" Height="30" Width="140" VerticalAlignment="Bottom"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- List Card -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Registered Holiday Periods" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextMainBrush}"/>
                        
                        <ListView Grid.Row="1" ItemsSource="{Binding HolidayLogs}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}">
                                                        <Run Text="{Binding StartDate, StringFormat=yyyy-MM-dd}"/>
                                                        <Run Text="  →  "/>
                                                        <Run Text="{Binding EndDate, StringFormat=yyyy-MM-dd}"/>
                                                    </TextBlock>
                                                    <Border CornerRadius="4" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Margin="10,0,0,0" Padding="6,1" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPublicHoliday}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="Public Holiday" FontSize="9" FontWeight="Bold" Foreground="#2563EB"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Note}" FontSize="11" Foreground="{StaticResource TextSecBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            
                                            <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="10" Padding="8,2" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock Text="{Binding WeekdayCount, StringFormat={}{0} weekdays}" FontSize="10" FontWeight="Bold" Foreground="#047857"/>
                                            </Border>
                                            
                                            <Button Grid.Column="2" Content="✕" Width="26" Height="26" VerticalAlignment="Center" 
                                                    Style="{StaticResource ModernButtonStyle}" Foreground="#EF4444" BorderBrush="#FCA5A5" Padding="0" FontSize="11"
                                                    Command="{Binding DataContext.DeleteHolidayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- 3b. WORK SCHEDULE VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentSettingsTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=Schedule}">
                <Border Style="{StaticResource CardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="Configure Daily Target Hours" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="Define your standard target work hours for each day of the week. These targets determine daily overtime threshold and weekly totals." FontSize="11" Foreground="{StaticResource TextSecBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,0,10,0">
                                <!-- Mon -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Monday Target:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextMainBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding TargetMon, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                                </Grid>

                                <!-- Tue -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Tuesday Target:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextMainBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding TargetTue, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                                </Grid>

                                <!-- Wed -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Wednesday Target:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextMainBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding TargetWed, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                                </Grid>

                                <!-- Thu -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Thursday Target:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextMainBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding TargetThu, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                                </Grid>

                                <!-- Fri -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Friday Target:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextMainBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding TargetFri, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                                </Grid>

                                <!-- Sat -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Saturday Target:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextMainBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding TargetSat, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                                </Grid>

                                <!-- Sun -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sunday Target:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextMainBrush}"/>
                                    <TextBox Grid.Column="1" Text="{Binding TargetSun, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource CardHeaderBgBrush}" Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Save Button -->
                        <Button Grid.Row="2" Content="💾 Save Work Schedule" Command="{Binding SaveScheduleCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="36" HorizontalAlignment="Left" Width="200" Margin="0,15,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 4. DIAGNOSTICS & LOGS VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentSettingsTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=Diagnostics}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Quick Actions -->
                    <RowDefinition Height="*" />    <!-- Log View -->
                    <RowDefinition Height="Auto" /> <!-- Footer Buttons -->
                </Grid.RowDefinitions>

                <!-- Quick Actions Panel -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Simulations &amp; Testing Actions:" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,10" />
                        <UniformGrid Columns="3" Margin="0,0,0,5">
                            <Button Content="💤 Sim Idle (15m)" Click="BtnSimIdle_Click" Style="{StaticResource PrimaryButtonStyle}" Height="34" Margin="0,0,8,0" ToolTip="Simulates returning from a 15-minute idle block" />
                            <Button Content="🔒 Sim Unlock (20m)" Click="BtnSimUnlock_Click" Style="{StaticResource PrimaryButtonStyle}" Height="34" Margin="0,0,8,0" ToolTip="Simulates returning from a 20-minute session lock" />
                            <Button Content="🔄 Sync Calendar" Click="BtnSyncCalendar_Click" Style="{StaticResource ModernButtonStyle}" Height="34" ToolTip="Forces an immediate calendar integration sync" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Logs Textbox Panel -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="System Event Logs:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,8" />
                        <TextBox Grid.Row="1" x:Name="TxtLogs" 
                                 IsReadOnly="True" 
                                 VerticalScrollBarVisibility="Auto" 
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Courier New" 
                                 FontSize="11" 
                                 Background="{StaticResource CardHeaderBgBrush}" 
                                 Foreground="{StaticResource TextMainBrush}" 
                                 BorderBrush="{StaticResource BorderBrush}" 
                                 Padding="8" />
                    </Grid>
                </Border>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,10">
                    <Button Content="Clear Logs" Click="BtnClearLogs_Click" Style="{StaticResource ModernButtonStyle}" Width="100" Height="34" />
                </StackPanel>
            </Grid>

            <!-- 5. UPDATE VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentSettingsTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=Update}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Action Panel -->
                    <RowDefinition Height="*" />    <!-- Update Log Panel -->
                </Grid.RowDefinitions>

                <!-- Check for Updates Action Card -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Keep Work Tracker Updated" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="Check for the latest updates directly from the official GitHub repository." FontSize="11" Foreground="{StaticResource TextSecBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Grid.Column="1" x:Name="BtnCheckUpdate" Content="Check for Updates" Click="BtnCheckUpdate_Click" Style="{StaticResource PrimaryButtonStyle}" Height="36" Width="160" VerticalAlignment="Center" ToolTip="Check for newer releases from GitHub" />
                    </Grid>
                </Border>

                <!-- Update Logs Card -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Update Progress &amp; Logs:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,8" />
                        <TextBox Grid.Row="1" x:Name="TxtUpdateLogs" 
                                 IsReadOnly="True" 
                                 VerticalScrollBarVisibility="Auto" 
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Courier New" 
                                 FontSize="11" 
                                 Background="{StaticResource CardHeaderBgBrush}" 
                                 Foreground="{StaticResource TextMainBrush}" 
                                 BorderBrush="{StaticResource BorderBrush}" 
                                 Padding="8" />
                    </Grid>
                </Border>
            </Grid>

            <!-- 6. ABOUT APP VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentSettingsTab, Converter={StaticResource TabToVisibilityConverter}, ConverterParameter=About}">
                <!-- Content Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0" Padding="25">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <!-- Logo and Title -->
                            <RowDefinition Height="Auto" /> <!-- Description -->
                            <RowDefinition Height="*" />    <!-- Details/Credits -->
                        </Grid.RowDefinitions>

                        <!-- Logo and Title Block -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
                            <Image Source="pack://application:,,,/app_icon.png" Width="64" Height="64" Margin="0,0,15,0" RenderOptions.BitmapScalingMode="HighQuality" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Work Tracker" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                                <TextBlock x:Name="TxtAboutVersion" Text="v1.4.2" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextSecBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Description Block -->
                        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
                            <TextBlock Text="Work Tracker is a smart utility designed to track your daily work timeline, active sessions, and meetings, calculate overtime, sync calendar events, and manage holidays. It helps keep your focus and automatically monitors your active hours." 
                                       FontSize="13" Foreground="{StaticResource TextMainBrush}" TextWrapping="Wrap" LineHeight="18" />
                        </Border>

                        <!-- Details Block -->
                        <StackPanel Grid.Row="2">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Developer:" FontWeight="SemiBold" Foreground="{StaticResource TextSecBrush}" />
                                <TextBlock Grid.Column="1" Text="Gustings" Foreground="{StaticResource TextMainBrush}" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="GitHub Repository:" FontWeight="SemiBold" Foreground="{StaticResource TextSecBrush}" />
                                <TextBlock Grid.Column="1">
                                    <Hyperlink NavigateUri="https://github.com/Gustings/WorkTracker" RequestNavigate="Hyperlink_RequestNavigate">
                                        https://github.com/Gustings/WorkTracker
                                    </Hyperlink>
                                </TextBlock>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Platform:" FontWeight="SemiBold" Foreground="{StaticResource TextSecBrush}" />
                                <TextBlock Grid.Column="1" Text=".NET 9.0 (WPF / Windows)" Foreground="{StaticResource TextMainBrush}" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
