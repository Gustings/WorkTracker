<Window x:Class="WorkTracker.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Work Tracker Summary" Height="245" Width="290"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" Deactivated="Window_Deactivated">
    
    <Border Background="{StaticResource CardBgBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Padding="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Color="#0F172A" Opacity="0.15" Direction="270" />
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/app_icon.png" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Work Tracker" FontFamily="{StaticResource MainFont}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecBrush}" 
                        FontWeight="Bold" FontSize="12" Cursor="Hand" Click="CloseBtn_Click" Width="20" Height="20">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource LeisureBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Separator Grid.Row="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

            <!-- Content Grid -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Row 0: Weekly worked -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📊" Margin="0,0,8,0" FontSize="12"/>
                    <TextBlock Text="Time Worked (Week):" FontSize="12" Foreground="{StaticResource TextSecBrush}"/>
                </StackPanel>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WeeklyHoursText}" 
                           FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextMainBrush}" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <!-- Row 1: Weekly Overtime -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚡" Margin="0,0,8,0" FontSize="12"/>
                    <TextBlock Text="Overtime Earned:" FontSize="12" Foreground="{StaticResource TextSecBrush}"/>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WeeklyOvertimeEarned, StringFormat={}{0:F2} hrs}" 
                           FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource PrimaryAccentBrush}" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <!-- Row 2: Time Off this week -->
                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🌴" Margin="0,0,8,0" FontSize="12"/>
                    <TextBlock Text="Time Off (Week):" FontSize="12" Foreground="{StaticResource TextSecBrush}"/>
                </StackPanel>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WeeklyTimeOffCredit, StringFormat={}{0:F1} hrs}" 
                           FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TimeOffBrush}" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <!-- Row 3: Flex Balance -->
                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⏱️" Margin="0,0,8,0" FontSize="12"/>
                    <TextBlock Text="Flex Balance:" FontSize="12" Foreground="{StaticResource TextSecBrush}"/>
                </StackPanel>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LifetimeOvertimeText}" 
                           FontWeight="Bold" FontSize="12" Foreground="{StaticResource SecondaryAccentBrush}" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <!-- Row 4: Holiday Balance -->
                <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✈️" Margin="0,0,8,0" FontSize="12"/>
                    <TextBlock Text="Holiday Balance:" FontSize="12" Foreground="{StaticResource TextSecBrush}"/>
                </StackPanel>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding HolidayBalanceText}" 
                           FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource HolidayBrush}" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <!-- Footer Link -->
            <TextBlock Grid.Row="3" Text="Open Dashboard" Foreground="{StaticResource PrimaryAccentBrush}" 
                       FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" Margin="0,14,0,0" 
                       Cursor="Hand" MouseLeftButtonDown="OpenDashboard_Click" TextDecorations="Underline">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#4F46E5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</Window>
