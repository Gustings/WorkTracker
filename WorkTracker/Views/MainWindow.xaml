<Window x:Class="WorkTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WorkTracker.ViewModels"
        Title="Work Tracker" Height="700" Width="1000" MinHeight="700" MinWidth="1000"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/app_icon.png">
    
    <Window.Resources>
        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="45" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CaptionButtonStyleClose" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FEE2E2" />
                    <Setter Property="Foreground" Value="#EF4444" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="6" 
                      GlassFrameThickness="0,0,1,0"/>
    </WindowChrome.WindowChrome>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" /> <!-- Left Sidebar Navigation -->
            <ColumnDefinition Width="1*" />  <!-- Main Content Area -->
        </Grid.ColumnDefinitions>

        <!-- Custom Caption Buttons (Top Right Corner of entire window) -->
        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Height="40" Margin="0,0,10,0" WindowChrome.IsHitTestVisibleInChrome="True" Panel.ZIndex="999">
            <Button Style="{StaticResource CaptionButtonStyle}" Content="—" Click="MinimizeBtn_Click" ToolTip="Minimize"/>
            <Button Style="{StaticResource CaptionButtonStyle}" Content="☐" Click="MaximizeBtn_Click" ToolTip="Maximize"/>
            <Button Style="{StaticResource CaptionButtonStyleClose}" Content="✕" Click="CloseBtn_Click" ToolTip="Close"/>
        </StackPanel>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="15,35,15,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Logo/Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Image Source="/app_icon.png" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Work Tracker" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Tabs Buttons -->
                <StackPanel Grid.Row="2" Margin="0,20,0,0">
                    <Button Content="📊 Dashboard" Command="{Binding SetTabCommand}" CommandParameter="Dashboard">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentTab}" Value="Dashboard">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📅 Daily Timeline" Command="{Binding SetTabCommand}" CommandParameter="Timeline">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentTab}" Value="Timeline">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🗓️ Week View" Command="{Binding SetTabCommand}" CommandParameter="Week View">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentTab}" Value="Week View">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="📅 Calendar View" Command="{Binding SetTabCommand}" CommandParameter="Calendar View">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentTab}" Value="Calendar View">
                                        <Setter Property="Tag" Value="Active" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Footer: Flex/Overtime Status pill & Settings -->
                <StackPanel Grid.Row="3" VerticalAlignment="Bottom" Margin="0,0,0,10">
                    <Border Background="{StaticResource CardHeaderBgBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="FLEX BALANCE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding LifetimeOvertimeText}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SecondaryAccentBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardHeaderBgBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="HOLIDAY BALANCE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding HolidayBalanceText}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryAccentBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    
                    <Button x:Name="BtnSettings" Content="⚙️ Settings" Click="BtnSettings_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="25,35,25,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- View Header -->
                <RowDefinition Height="*" />    <!-- Active View Content -->
            </Grid.RowDefinitions>

            <!-- Main Title Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="{Binding CurrentTab}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center" />
                
                <!-- Refresh / Date navigation elements on header depending on view -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Dashboard Date Scroller -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding CurrentTab, Converter={StaticResource ResourceKey=TabToVisibilityConverter}, ConverterParameter=Dashboard}">
                        <Button Content="&lt; Prev Week" Style="{StaticResource ModernButtonStyle}" Command="{Binding PrevWeekCommand}" Margin="5,0"/>
                        <TextBlock Text="{Binding SelectedWeekText}" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center" Margin="10,0" FontWeight="SemiBold"/>
                        <Button Content="This Week" Style="{StaticResource ModernButtonStyle}" Command="{Binding ThisWeekCommand}" Margin="5,0"/>
                        <Button Content="Next Week &gt;" Style="{StaticResource ModernButtonStyle}" Command="{Binding NextWeekCommand}" Margin="5,0"/>
                    </StackPanel>

                    <!-- WeekView Date Scroller -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding CurrentTab, Converter={StaticResource ResourceKey=TabToVisibilityConverter}, ConverterParameter=Week View}">
                        <Button Content="&lt; Prev Week" Style="{StaticResource ModernButtonStyle}" Command="{Binding PrevWeekCommand}" Margin="5,0"/>
                        <TextBlock Text="{Binding SelectedWeekText}" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center" Margin="10,0" FontWeight="SemiBold"/>
                        <Button Content="This Week" Style="{StaticResource ModernButtonStyle}" Command="{Binding ThisWeekCommand}" Margin="5,0"/>
                        <Button Content="Next Week &gt;" Style="{StaticResource ModernButtonStyle}" Command="{Binding NextWeekCommand}" Margin="5,0"/>
                    </StackPanel>

                    <!-- Timeline Date Scroller -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding CurrentTab, Converter={StaticResource ResourceKey=TabToVisibilityConverter}, ConverterParameter=Timeline}">
                        <Button Content="&lt; Prev Day" Style="{StaticResource ModernButtonStyle}" Command="{Binding PrevDayCommand}" Margin="5,0"/>
                        <TextBlock Text="{Binding SelectedDateText}" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center" Margin="10,0" FontWeight="SemiBold"/>
                        <Button Content="Today" Style="{StaticResource ModernButtonStyle}" Command="{Binding TodayCommand}" Margin="5,0"/>
                        <Button Content="Next Day &gt;" Style="{StaticResource ModernButtonStyle}" Command="{Binding NextDayCommand}" Margin="5,0"/>
                    </StackPanel>

                    <!-- CalendarView Date Scroller -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding CurrentTab, Converter={StaticResource ResourceKey=TabToVisibilityConverter}, ConverterParameter=Calendar View}">
                        <Button Content="&lt; Prev Month" Style="{StaticResource ModernButtonStyle}" Command="{Binding PrevMonthCommand}" Margin="5,0"/>
                        <TextBlock Text="{Binding CalendarMonthText}" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center" Margin="10,0" FontWeight="SemiBold"/>
                        <Button Content="Next Month &gt;" Style="{StaticResource ModernButtonStyle}" Command="{Binding NextMonthCommand}" Margin="5,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Dynamic Views Switcher using Visibility bindings -->
            
            <!-- 1. DASHBOARD VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentTab, Converter={StaticResource ResourceKey=TabToVisibilityConverter}, ConverterParameter=Dashboard}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                
                <!-- Top Summary Cards -->
                <UniformGrid Grid.Row="0" Columns="3" Margin="-10,0,-10,15">
                    <!-- Weekly Hours -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="WEEKLY WORKED" FontSize="11" Foreground="{StaticResource TextSecBrush}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding WeeklyHoursText}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,8"/>
                            <ProgressBar Value="{Binding WeeklyProgressPercent, Mode=OneWay}" Height="6" Foreground="{StaticResource PrimaryAccentBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Week's Earned Overtime -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="WEEKLY OVERTIME EARNED" FontSize="11" Foreground="{StaticResource TextSecBrush}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding WeeklyOvertimeEarned, StringFormat={}{0:F2} hrs}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SecondaryAccentBrush}" Margin="0,0,0,3"/>
                            <TextBlock Text="Calculated with multipliers" FontSize="11" Foreground="{StaticResource TextSecBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Time Off Credit -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TIME OFF CREDIT (THIS WEEK)" FontSize="11" Foreground="{StaticResource TextSecBrush}" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding WeeklyTimeOffCredit, StringFormat={}{0:F1} hrs}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource MeetingBrush}" Margin="0,0,0,3"/>
                            <TextBlock Text="Subtracted from weekly target" FontSize="11" Foreground="{StaticResource TextSecBrush}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
                        <!-- Daily Breakdown -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Top Applications Used Today" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource TextMainBrush}"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding TopApps}" Margin="0,5">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource CardHeaderBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="15,12" Margin="0,4" HorizontalAlignment="Stretch">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="100" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- App Details -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding ProcessName}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextMainBrush}" />
                                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{StaticResource TextSecBrush}" />
                                                </StackPanel>
                                                
                                                <!-- Pill Color Indicator -->
                                                <Border Grid.Column="1" Width="85" Height="22" CornerRadius="11" Margin="0,0,15,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource HoverBgBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Category}" Value="Work">
                                                                    <Setter Property="Background" Value="#EEF2FF"/>
                                                                    <Setter Property="BorderBrush" Value="#C7D2FE"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Category}" Value="Offline Work">
                                                                    <Setter Property="Background" Value="#ECFDF5"/>
                                                                    <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Category}" Value="Meeting">
                                                                    <Setter Property="Background" Value="#F5F3FF"/>
                                                                    <Setter Property="BorderBrush" Value="#DDD6FE"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Category}" Value="Leisure">
                                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                                    <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Category}" Value="Idle">
                                                                    <Setter Property="Background" Value="#FFFBEB"/>
                                                                    <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                
                                                <!-- Duration -->
                                                <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource PrimaryAccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- 2. TIMELINE VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentTab, Converter={StaticResource ResourceKey=TabToVisibilityConverter}, ConverterParameter=Timeline}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <!-- Timeline List Card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Timeline blocks show dominant active apps per 30-minute intervals. Click a block to edit its activity classification." FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,15" />
                        
                        <ListView Grid.Row="1" ItemsSource="{Binding Timeline}" SelectedItem="{Binding SelectedTimelineBlock, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="5,2">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource HoverBgBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EEF2FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6" Background="Transparent" Cursor="Hand">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" /> <!-- Time Label -->
                                            <ColumnDefinition Width="35" />  <!-- Timeline Line & Dot -->
                                            <ColumnDefinition Width="*" />   <!-- Application details -->
                                            <ColumnDefinition Width="Auto" /> <!-- Edit Button -->
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" Text="{Binding TimeLabel}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextSecBrush}" FontSize="13"/>
                                        
                                        <!-- Vertical line & circle path -->
                                        <Grid Grid.Column="1" HorizontalAlignment="Center">
                                            <!-- Vertical timeline connector -->
                                            <Rectangle Width="2" Fill="{StaticResource BorderBrush}" Margin="0,-12,0,-12"/>
                                            
                                            <!-- The dot -->
                                            <Ellipse Width="12" Height="12" VerticalAlignment="Center" Stroke="White" StrokeThickness="1.5">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource IgnoreBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Category}" Value="Work">
                                                                <Setter Property="Fill" Value="{StaticResource PrimaryAccentBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Offline Work">
                                                                <Setter Property="Fill" Value="{StaticResource SecondaryAccentBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Meeting">
                                                                <Setter Property="Fill" Value="{StaticResource MeetingBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Leisure">
                                                                <Setter Property="Fill" Value="{StaticResource LeisureBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Idle">
                                                                <Setter Property="Fill" Value="{StaticResource IdleBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Vacation">
                                                                <Setter Property="Fill" Value="{StaticResource TimeOffBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Holiday">
                                                                <Setter Property="Fill" Value="{StaticResource HolidayBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Sick Day">
                                                                <Setter Property="Fill" Value="{StaticResource SickBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Time Off">
                                                                <Setter Property="Fill" Value="{StaticResource TimeOffBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </Grid>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding AppDetails}" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Category}" Value="Away">
                                                            <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Edit button visible on hover -->
                                        <Button Grid.Column="3" Click="TimelineBlockEdit_Click" ToolTip="Edit timeline block" Width="24" Height="24" Margin="5,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="✏️" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
                
                <!-- Today's Calendar Events Panel (Right Side) -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Width="300" Margin="10,0,0,0" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="📅 Today's Calendar Events" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" Foreground="{StaticResource TextMainBrush}"/>
                        
                        <ListView Grid.Row="1" ItemsSource="{Binding DailyEvents}" Background="Transparent" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextMainBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding TimeLabel}" FontSize="11" Foreground="{StaticResource TextSecBrush}"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Height="20" CornerRadius="10" Padding="8,2" VerticalAlignment="Center" Margin="5,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource HoverBgBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Category}" Value="Meeting">
                                                                <Setter Property="Background" Value="#F5F3FF"/> <!-- Lavender -->
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Offline Work">
                                                                <Setter Property="Background" Value="#ECFDF5"/> <!-- Mint -->
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Category}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Visibility="{Binding CurrentTab, Converter={StaticResource ResourceKey=TabToVisibilityConverter}, ConverterParameter=Categories}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="310" />
                </Grid.ColumnDefinitions>
                
                <!-- Registered Apps List -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="App Classifications" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource TextMainBrush}"/>
                        
                        <ListView Grid.Row="1" ItemsSource="{Binding AppCategories}" 
                                  SelectedItem="{Binding SelectedAppCategory, Mode=TwoWay}"
                                  Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ProcessName}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Background="{StaticResource HoverBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,4">
                                                <TextBlock Text="{Binding CategoryName}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
                
                <!-- Rule Edit Panel -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Edit App Rule" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource TextMainBrush}"/>
                        
                        <TextBlock Text="Process Name:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding SelectedProcessName, UpdateSourceTrigger=PropertyChanged}" Background="{StaticResource CardHeaderBgBrush}" 
                                 Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Category:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,5"/>
                        <ComboBox SelectedValue="{Binding SelectedCategoryValue}" SelectedValuePath="Content" Background="{StaticResource CardHeaderBgBrush}" 
                                  Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8" Margin="0,0,0,20">
                            <ComboBoxItem Content="Work" />
                            <ComboBoxItem Content="Meeting" />
                            <ComboBoxItem Content="Leisure" />
                            <ComboBoxItem Content="Ignore" />
                        </ComboBox>
                        
                        <Button Content="Save Classification" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCategoryCommand}" Margin="0,0,0,8"/>
                        <Button Content="Delete Classification" Style="{StaticResource ModernButtonStyle}" Command="{Binding DeleteCategoryCommand}" Foreground="#EF4444" BorderBrush="#FCA5A5"/>
                    </StackPanel>
                </Border>

                <!-- Calendar Integration Panel -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="10,0,0,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="📅 Calendar Integration" FontSize="16" FontWeight="Bold" Margin="0,0,0,6" Foreground="{StaticResource TextMainBrush}"/>
                        <TextBlock Text="Auto-imports calendar events every hour via Google Calendar" FontSize="11" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,18" TextWrapping="Wrap"/>

                        <TextBlock Text="Google Calendar ICS URL:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding IcsCalendarUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource CardHeaderBgBrush}"
                                 Foreground="{StaticResource TextMainBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 Padding="8" Margin="0,0,0,6"
                                 TextWrapping="Wrap" AcceptsReturn="False"
                                 ToolTip="Paste your Google Calendar secret ICS URL here (from Settings → Integrate calendar)"/>
                        <Button Content="Save &amp; Sync Now" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveIcsUrlCommand}" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding IcsSyncStatus}" FontSize="11" Foreground="{StaticResource TextSecBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- 4. WEEK VIEW (COMBINED) -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentTab, Converter={StaticResource ResourceKey=TabToVisibilityConverter}, ConverterParameter=Week View}">
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="Weekly Time Off &amp; Overtime Gained" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" Foreground="{StaticResource TextMainBrush}"/>
                            <TextBlock Text="Track daily worked hours, registered time off, and accumulated overtime. Click the edit icon to manually log offline hours, overtime rates, or time off days." 
                                       TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecBrush}"/>
                        </StackPanel>
                        
                        <ListView Grid.Row="1" ItemsSource="{Binding WeeklyEarnings}" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardHeaderBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="15,12" Margin="0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" /> <!-- Day & Date -->
                                                <ColumnDefinition Width="110" /> <!-- Worked Hours -->
                                                <ColumnDefinition Width="110" /> <!-- Time Off Registered -->
                                                <ColumnDefinition Width="110" /> <!-- Gained (ot) -->
                                                <ColumnDefinition Width="*" />   <!-- Change Icon -->
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Column 0: Day & Date -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DayName}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/>
                                                <TextBlock Text="{Binding DateText}" FontSize="10" Foreground="{StaticResource TextSecBrush}"/>
                                            </StackPanel>
                                            
                                            <!-- Column 1: Worked Hours -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Worked" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,2"/>
                                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0:F1}h / {1:F1}h">
                                                            <Binding Path="HoursWorked" />
                                                            <Binding Path="TargetHours" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <!-- Column 2: Time Off Registered -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="Time Off" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,2"/>
                                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MeetingBrush}">
                                                    <TextBlock.Text>
                                                        <Binding Path="TimeOffCredit" StringFormat="{}{0:F1} hrs" />
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <!-- Column 3: Gained Time Off -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                <TextBlock Text="Gained" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,2"/>
                                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource SecondaryAccentBrush}">
                                                    <TextBlock.Text>
                                                        <Binding Path="GainedTimeOff" StringFormat="{}{0:+0.00;-0.00;0.00} hrs" />
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            
                                            <!-- Column 4: Change Icon button -->
                                            <Button Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Width="30" Height="30" 
                                                    Command="{Binding EditManualWorkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Add or edit manual work hours spent away from computer">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="✏️" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        
                        <!-- Bottom Weekly Summary Box -->
                        <Border Grid.Row="2" Background="{StaticResource CardHeaderBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Total Saved Up This Week: " FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding WeeklyOvertimeEarned, StringFormat={}{0:F2} hrs}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SecondaryAccentBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Weekly Worked: " FontSize="12" Foreground="{StaticResource TextSecBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding WeeklyHoursText}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                    
                                    <TextBlock Text="Weekly Time Off: " FontSize="12" Foreground="{StaticResource TextSecBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding WeeklyTimeOffCredit, StringFormat={}{0:F1} hrs}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource MeetingBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- 5. CALENDAR VIEW -->
            <Grid Grid.Row="1" Visibility="{Binding CurrentTab, Converter={StaticResource ResourceKey=TabToVisibilityConverter}, ConverterParameter=Calendar View}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <!-- Month Title -->
                        <TextBlock Grid.Row="0" Text="Monthly Overtime Gained Overview" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextMainBrush}"/>
                        
                        <!-- Day of Week Headers -->
                        <UniformGrid Grid.Row="1" Columns="7" Margin="0,5,0,5">
                            <TextBlock Text="Mon" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Tue" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Wed" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Thu" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Fri" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Sat" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Sun" FontWeight="Bold" Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center"/>
                        </UniformGrid>
                        
                        <!-- Grid cells -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding CalendarDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7" Rows="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0.5" Margin="2" CornerRadius="6" Padding="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                        <Setter Property="Background" Value="{StaticResource HoverBgBrush}"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </DataTrigger>
                                                    <!-- Time off used takes precedence (lavender) -->
                                                    <DataTrigger Binding="{Binding HasTimeOffUsed}" Value="True">
                                                        <Setter Property="Background" Value="#FAF5FF"/>
                                                    </DataTrigger>
                                                    <!-- Sick day — light blue -->
                                                    <DataTrigger Binding="{Binding HasSickDay}" Value="True">
                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                    </DataTrigger>
                                                    <!-- Green for overtime gained -->
                                                    <DataTrigger Binding="{Binding HasGained}" Value="True">
                                                        <Setter Property="Background" Value="#F0FDF4"/>
                                                    </DataTrigger>
                                                    <!-- Holiday/Public Holiday — light pink (applied last for priority on non-work days) -->
                                                    <DataTrigger Binding="{Binding HasHoliday}" Value="True">
                                                        <Setter Property="Background" Value="#FDF2F8"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <!-- Day number top-left -->
                                            <TextBlock Grid.Row="0" Text="{Binding DayNumber}" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Left"/>
                                            <!-- Labels stacked: green gain, purple time-off-used, blue sick day, pink holiday -->
                                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,2,0,0">
                                                <!-- Overtime gained — emerald green -->
                                                <TextBlock Text="{Binding GainedText}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource SecondaryAccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           Visibility="{Binding HasGained, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <!-- Time off used — purple -->
                                                <TextBlock Text="{Binding TimeOffUsedText}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource MeetingBrush}"
                                                           HorizontalAlignment="Center"
                                                           Visibility="{Binding HasTimeOffUsed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <!-- Sick day — sky blue -->
                                                <TextBlock Text="{Binding SickDayText}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="#3B82F6"
                                                           HorizontalAlignment="Center"
                                                           Visibility="{Binding HasSickDay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <!-- Holiday / Public Holiday — pink -->
                                                <TextBlock Text="{Binding HolidayText}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="#EC4899"
                                                           HorizontalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding HasHoliday, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
                
                <!-- Bottom Unlinked Time Off Panel -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="10,5,10,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Unlinked Time Off Gained: " FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding UnlinkedTimeOffTotal, StringFormat={}{0:F2} hrs}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SecondaryAccentBrush}" VerticalAlignment="Center"/>
                            <Button Command="{Binding EditUnlinkedCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Edit unlinked time off" Style="{StaticResource ModernButtonStyle}" Margin="15,0,0,0" Width="30" Height="30" Padding="0">
                                <TextBlock Text="✏️" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
