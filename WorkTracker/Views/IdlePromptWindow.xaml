<Window x:Class="WorkTracker.Views.IdlePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activity Prompt - Work Tracker" 
        Height="360" Width="480"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">
    
    <Border BorderThickness="2" BorderBrush="{StaticResource BorderBrush}" CornerRadius="12" Background="{StaticResource BgBrush}">
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Ellipse Width="12" Height="12" Fill="{StaticResource IdleBrush}" Margin="0,0,10,0" />
            <TextBlock x:Name="TxtHeader" Text="Welcome Back!" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
        </StackPanel>

        <!-- Time details for Inactive -->
        <TextBlock Grid.Row="1" x:Name="PanelInactive" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,15" Foreground="{StaticResource TextSecBrush}">
            You were inactive for <Run x:Name="TxtDuration" FontWeight="Bold" Foreground="{StaticResource IdleBrush}"/> minutes 
            from <Run x:Name="TxtStart" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/> 
            to <Run x:Name="TxtEnd" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/>.
        </TextBlock>

        <!-- Time details for Locked -->
        <TextBlock Grid.Row="1" x:Name="PanelLocked" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,15" Foreground="{StaticResource TextSecBrush}" Visibility="Collapsed">
            You locked your PC for <Run x:Name="TxtDurationLock" FontWeight="Bold" Foreground="{StaticResource IdleBrush}"/> minutes 
            from <Run x:Name="TxtStartLock" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/> 
            to <Run x:Name="TxtEndLock" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/>.
        </TextBlock>

        <!-- Classification Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <RadioButton x:Name="RadBreak" Content="Away / Break" Style="{StaticResource {x:Type ToggleButton}}" 
                         Width="120" Height="40" Margin="5" Padding="10" Background="{StaticResource CardHeaderBgBrush}" 
                         Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}"
                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <RadioButton x:Name="RadWork" Content="Offline Work" Style="{StaticResource {x:Type ToggleButton}}" 
                         Width="120" Height="40" Margin="5" Padding="10" Background="{StaticResource CardHeaderBgBrush}" 
                         Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}"
                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <RadioButton x:Name="RadMeeting" Content="Meeting" Style="{StaticResource {x:Type ToggleButton}}" 
                         Width="120" Height="40" Margin="5" Padding="10" Background="{StaticResource CardHeaderBgBrush}" 
                         Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}"
                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsChecked="True"/>
        </StackPanel>

        <!-- Description (Only relevant if Offline Work or Meeting is selected) -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=RadWork, Path=IsChecked}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ElementName=RadMeeting, Path=IsChecked}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="What were you doing?" FontSize="12" Margin="0,0,0,5" Foreground="{StaticResource TextSecBrush}"/>
            <TextBox Grid.Row="1" x:Name="TxtDescription" Background="{StaticResource CardBgBrush}" 
                     Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" 
                     Padding="8" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     BorderThickness="1" SelectionBrush="{StaticResource PrimaryAccentBrush}"/>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save Activity" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0" Width="120" Click="Save_Click"/>
            <Button Content="Discard / Skip" Style="{StaticResource ModernButtonStyle}" Width="100" Click="Cancel_Click"/>
        </StackPanel>
        </Grid>
    </Border>
</Window>
