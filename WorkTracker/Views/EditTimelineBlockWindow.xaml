<Window x:Class="WorkTracker.Views.EditTimelineBlockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Timeline Block" 
        Height="360" Width="360"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Icon="pack://application:,,,/app_icon.png"
        WindowStartupLocation="CenterOwner">
    
    <Border BorderThickness="2" BorderBrush="{StaticResource BorderBrush}" CornerRadius="16" Background="{StaticResource BgBrush}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="*" />    <!-- Content -->
                <RowDefinition Height="Auto" /> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <Ellipse Width="12" Height="12" Fill="{StaticResource PrimaryAccentBrush}" Margin="0,0,10,0" />
                <TextBlock Text="Edit Timeline Block" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
            </StackPanel>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Selected Interval:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,3"/>
                <TextBlock x:Name="TxtInterval" Text="12:00 - 12:30" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryAccentBrush}" Margin="0,0,0,15"/>

                <TextBlock Text="Activity Description:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtDescription" Background="{StaticResource CardHeaderBgBrush}" 
                         Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8" Margin="0,0,0,15"/>

                <TextBlock Text="Category:" FontSize="12" Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,5"/>
                <ComboBox x:Name="CbCategory" Background="{StaticResource CardHeaderBgBrush}" 
                          Foreground="{StaticResource TextMainBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8" Margin="0,0,0,10">
                    <ComboBoxItem Content="Work" />
                    <ComboBoxItem Content="Meeting" />
                    <ComboBoxItem Content="Leisure" />
                    <ComboBoxItem Content="Offline Work" />
                    <ComboBoxItem Content="Away" />
                </ComboBox>
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="2">
                <Button Content="Delete" Style="{StaticResource DangerButtonStyle}" HorizontalAlignment="Left" Padding="15,8" Click="Delete_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save Changes" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Padding="15,8" Click="Save_Click"/>
                    <Button Content="Cancel" Style="{StaticResource ModernButtonStyle}" Padding="15,8" Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
